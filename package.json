{
  "name": "ezprofile",
  "version": "1.0.0",
  "description": "Multi Chrome Profile Manager - Quản lý đa profile Chrome",
  "homepage": "https://github.com/ezprofile/ezprofile",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently \"cross-env NODE_ENV=development vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development ELECTRON_DISABLE_SANDBOX=1 electron .\"",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.ezprofile.app",
    "productName": "EzProfile",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "ezprofile",
      "repo": "ezprofile"
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**"
    ],
    "afterPack": "./scripts/afterPack.js",
    "extraResources": [
      {
        "from": "public/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "Utility",
      "maintainer": "EzProfile Team"
    },
    "deb": {
      "afterInstall": "scripts/afterInstall.sh",
      "afterRemove": "scripts/afterRemove.sh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.utilities"
    }
  },
  "keywords": [
    "chrome",
    "profile",
    "manager",
    "multi-account"
  ],
  "author": "EzProfile Team",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^11.9.1",
    "electron-serve": "^2.1.1",
    "electron-updater": "^6.8.3",
    "i18next": "^25.10.9",
    "puppeteer-core": "^24.40.0",
    "react-i18next": "^16.6.6",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.2",
    "electron-builder": "^25.1.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.2",
    "vite": "^6.3.1",
    "wait-on": "^8.0.3"
  }
}
